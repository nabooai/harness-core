# harness-core — environment variables. Copy to `.env` and fill in, or `export` them.
# Everything here is read from the environment by the SDKs; nothing is hardcoded.

# ── Model credentials (the agent + the judge call a model) ──────────────────────
# Set the one(s) for the models you use. Bare model names (e.g. "gpt-4o-mini") use OpenAI;
# "provider/..." names (e.g. "gemini/...") are routed by litellm and read that provider's key.
OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# ANTHROPIC_API_KEY=...

# ── LangSmith (only if you use tracing: run_suite_traced / `harness-core run --traced`) ──
# Get a key at https://smith.langchain.com → Settings → API Keys. The LangSmith SDK reads
# LANGSMITH_API_KEY automatically; you can also pass it programmatically:
#   enable_langsmith(api_key="lsv2_...")   /   run_suite_traced(..., api_key="lsv2_...")
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=harness-core          # groups runs; optional (defaults to "default")
LANGSMITH_TRACING=true                  # enables the LangSmith SDK auto-tracing paths

# ── Dashboard / readers (optional) ──────────────────────────────────────────────
# Where `harness-core server` / `list` / `pull` look for run dirs (else auto-discover under CWD).
# HARNESS_RUNS_ROOTS=fdav14=fdav14/runs,explore=explore/runs
# HARNESS_RUNS_BASE=.
